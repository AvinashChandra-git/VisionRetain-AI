# ─── VisionRetain AI — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/visionretain
REDIS_HOST=localhost
REDIS_PASSWORD=your_redis_password_here

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_256_bit_jwt_secret_key_minimum_32_characters_long
BCRYPT_STRENGTH=12

# ── AI (Required for Product Lens, Copilot, Sentiment, Reports) ───────────────
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# ── AWS (For image storage + deployment) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=visionretain-product-images
AWS_REGION=ap-south-1

# ── Email Notifications ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@visionretain.ai
SMTP_PASSWORD=your_app_password

# ── Slack Alerts ──────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxx

# ── ML Service ────────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://ml:8001
ML_CACHE_TTL_SECONDS=21600

# ── App Config ────────────────────────────────────────────────────────────────
APP_ENV=production
APP_PORT=8080
CORS_ORIGINS=https://app.visionretain.ai,http://localhost:3000
LOG_LEVEL=INFO
